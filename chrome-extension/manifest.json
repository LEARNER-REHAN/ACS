{
  "manifest_version": 3,
  "name": "Addiction Tracker",
  "version": "1.0",
  "description": "Tracks social media usage automatically",

  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  }
}