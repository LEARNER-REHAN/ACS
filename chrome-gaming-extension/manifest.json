{
  "manifest_version": 3,
  "name": "Gaming Tracker",
  "version": "1.0",
  "description": "Tracks gaming website usage",

  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  }
}